diff --git a/sysfile.c b/sysfile.c
index bfe61b7..6ee90f8 100644
--- a/sysfile.c
+++ b/sysfile.c
@@ -442,3 +442,32 @@ sys_pipe(void)
   fd[1] = fd1;
   return 0;
 }
+
+int sys_lseek(void)
+{
+  int fd, offset, whence, newoff;
+  struct file *fp;
+
+  if(argint(0, &fd) == -1 || argint(1, &offset) == -1 || argint(2, &whence) == -1)
+    return -1;
+
+  fp = myproc()->ofile[fd];
+  if(!fp || fp->type != FD_INODE){
+    return -1;
+  }
+
+  if(whence == SEEK_SET)
+    newoff = offset;
+  else if(whence == SEEK_CUR)
+    newoff = fp->off + offset;
+  else if(whence == SEEK_END)
+    newoff = fp->ip->size + offset;
+  else
+    return -1;
+
+  if(newoff < 0)
+    return -1;
+
+  fp->off = newoff;
+  return newoff;
+}
